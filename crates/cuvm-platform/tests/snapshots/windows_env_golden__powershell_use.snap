if ($env:CUVM_INJECTED) {
  $cuvm_inj = $env:CUVM_INJECTED -split ';'
  $env:Path = (($env:Path -split ';') | Where-Object { $_ -and ($cuvm_inj -notcontains $_) }) -join ';'
}
